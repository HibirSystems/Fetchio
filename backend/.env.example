# Application
APP_NAME=Fetchio API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
ALLOWED_ORIGINS=["*"]

# Database
DATABASE_URL=sqlite+aiosqlite:///./fetchio.db

# Redis (optional – used for distributed caching)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# Downloads
DOWNLOAD_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=3
MAX_FILE_SIZE_MB=2048

# yt-dlp
YTDLP_PROXY=
YTDLP_COOKIES_FILE=
YTDLP_MAX_RETRIES=3

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Security
SECRET_KEY=change-me-in-production-use-long-random-string
API_KEYS=[]
